<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.dada.app.ui.home.HomeFragment"
        android:label="首页"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_home_to_detail"
            app:destination="@id/detailFragment" />
    </fragment>

    <fragment
        android:id="@+id/detailFragment"
        android:name="com.dada.app.ui.home.DetailFragment"
        android:label="详情"
        tools:layout="@layout/fragment_detail">
        <argument
            android:name="postId"
            app:argType="integer" />
        <argument
            android:name="title"
            app:argType="string"
            android:defaultValue="" />
    </fragment>

    <fragment
        android:id="@+id/userFragment"
        android:name="com.dada.app.ui.user.UserFragment"
        android:label="用户"
        tools:layout="@layout/fragment_user" />

    <fragment
        android:id="@+id/mineFragment"
        android:name="com.dada.app.ui.MineFragment"
        android:label="我的"
        tools:layout="@layout/fragment_mine" />

    <fragment
        android:id="@+id/miHomeFragment"
        android:name="com.dada.app.ui.mihome.MiHomeFragment"
        android:label="米家设备"
        tools:layout="@layout/fragment_mi_home">
        <action
            android:id="@+id/action_miHome_to_miLogin"
            app:destination="@id/miLoginFragment" />
    </fragment>

    <fragment
        android:id="@+id/miLoginFragment"
        android:name="com.dada.app.ui.mihome.MiLoginFragment"
        android:label="小米登录"
        tools:layout="@layout/fragment_mi_login">
        <action
            android:id="@+id/action_miLogin_to_miHome"
            app:destination="@id/miHomeFragment"
            app:popUpTo="@id/miLoginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/coroutineExampleFragment"
        android:name="com.dada.app.ui.search.SearchExampleFragment"
        android:label="防抖节流示列"
        tools:layout="@layout/fragment_search_example" />

</navigation>
