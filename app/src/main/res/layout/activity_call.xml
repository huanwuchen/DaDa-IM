<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC000000">

    <!-- 视频容器（视频通话时显示） -->
    <FrameLayout
        android:id="@+id/video_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:visibility="visible">

        <!-- 远端视频（大窗口，全屏） -->
        <SurfaceView
            android:id="@+id/surface_remote"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

<!--        <androidx.constraintlayout.widget.ConstraintLayout-->
<!--            android:layout_width="match_parent"-->
<!--            android:layout_height="match_parent">-->

<!--            <SurfaceView-->
<!--                android:id="@+id/surface_remote"-->
<!--                android:layout_width="0dp"-->
<!--                android:layout_height="0dp"-->
<!--                app:layout_constraintDimensionRatio="4:3"-->
<!--                app:layout_constraintStart_toStartOf="parent"-->
<!--                app:layout_constraintEnd_toEndOf="parent"-->
<!--                app:layout_constraintTop_toTopOf="parent" />-->

<!--        </androidx.constraintlayout.widget.ConstraintLayout>-->



        <!-- 本地视频（小窗口，右上角）- 使用 CameraView 替代 SurfaceView
             CameraView 自动管理摄像头生命周期，并提供 FrameProcessor 获取 YUV 帧 -->
        <com.otaliastudios.cameraview.CameraView
            android:id="@+id/camera_local"
            android:layout_width="120dp"
            android:layout_height="160dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="48dp"
            android:layout_marginEnd="16dp"
            app:cameraFacing="front"
            app:cameraAudio="off"
            app:cameraMode="picture"
            app:cameraExperimental="true" />
    </FrameLayout>

    <!-- 通话信息区域 -->
    <LinearLayout
        android:id="@+id/layout_call_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@id/layout_call_actions"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.35">

        <!-- 头像 -->
        <ImageView
            android:id="@+id/iv_avatar"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:background="@drawable/bg_avatar"
            android:contentDescription="头像"
            android:padding="20dp"
            android:src="@drawable/ic_chat_emoji"
            android:tint="@android:color/white" />

        <!-- 用户名 -->
        <TextView
            android:id="@+id/tv_username"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:textColor="@android:color/white"
            android:textSize="24sp"
            android:textStyle="bold"
            tools:text="用户昵称" />

        <!-- 通话状态 -->
        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="#BBBBBB"
            android:textSize="16sp"
            tools:text="呼叫中..." />
    </LinearLayout>

    <!-- 操作按钮区域 -->
    <LinearLayout
        android:id="@+id/layout_call_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingBottom="64dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- 来电按钮组（接听 + 拒绝） -->
        <LinearLayout
            android:id="@+id/layout_incoming_actions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:visibility="gone"
            tools:visibility="visible">

            <!-- 接听 -->
            <LinearLayout
                android:id="@+id/btn_accept"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="@drawable/bg_call_accept"
                    android:contentDescription="接听"
                    android:padding="20dp"
                    android:src="@drawable/ic_call" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="接听"
                    android:textColor="@android:color/white"
                    android:textSize="14sp" />
            </LinearLayout>

            <View
                android:layout_width="64dp"
                android:layout_height="0dp" />

            <!-- 拒绝 -->
            <LinearLayout
                android:id="@+id/btn_reject"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="@drawable/bg_call_reject"
                    android:contentDescription="拒绝"
                    android:padding="20dp"
                    android:src="@drawable/ic_call_end" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="拒绝"
                    android:textColor="@android:color/white"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- 通话中按钮组（静音 + 挂断） -->
        <LinearLayout
            android:id="@+id/layout_in_call_actions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:visibility="gone"
            tools:visibility="visible">

            <!-- 静音 -->
            <LinearLayout
                android:id="@+id/btn_mute"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/iv_mute"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_call_mute"
                    android:contentDescription="静音"
                    android:padding="14dp"
                    android:src="@drawable/ic_mic_off" />

                <TextView
                    android:id="@+id/tv_mute_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="静音"
                    android:textColor="@android:color/white"
                    android:textSize="14sp" />
            </LinearLayout>

            <View
                android:layout_width="48dp"
                android:layout_height="0dp" />

            <!-- 切换摄像头（仅视频通话时显示） -->
            <LinearLayout
                android:id="@+id/btn_switch_camera"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="visible">

                <ImageView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_call_switch"
                    android:contentDescription="切换摄像头"
                    android:padding="14dp"
                    android:src="@drawable/ic_camera_switch" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="翻转"
                    android:textColor="@android:color/white"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- 切换摄像头按钮和挂断按钮之间的间距（默认 gone，与按钮一起显隐） -->
            <View
                android:id="@+id/space_switch_camera"
                android:layout_width="48dp"
                android:layout_height="0dp"
                android:visibility="gone"
                tools:visibility="visible" />

            <!-- 挂断 -->
            <LinearLayout
                android:id="@+id/btn_hangup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="@drawable/bg_call_reject"
                    android:contentDescription="挂断"
                    android:padding="20dp"
                    android:src="@drawable/ic_call_end" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="挂断"
                    android:textColor="@android:color/white"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- 去电按钮组（只有挂断） -->
        <LinearLayout
            android:id="@+id/layout_outgoing_actions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <ImageView
                android:id="@+id/btn_cancel"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/bg_call_reject"
                android:contentDescription="取消"
                android:padding="20dp"
                android:src="@drawable/ic_call_end" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="取消"
                android:textColor="@android:color/white"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
