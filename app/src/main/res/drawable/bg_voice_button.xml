<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/wechat_voice_button_pressed" />
            <corners android:radius="4dp" />
            <stroke android:width="0.5dp" android:color="@color/wechat_divider" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/wechat_voice_button_normal" />
            <corners android:radius="4dp" />
            <stroke android:width="0.5dp" android:color="@color/wechat_divider" />
        </shape>
    </item>
</selector>
