<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.DaDaNew" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowBackground">@color/background</item>
    </style>

    <style name="BottomNavTextActive" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="BottomNavTextInactive" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">11sp</item>
    </style>

    <style name="CallActivityTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@android:color/black</item>
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="ImageViewerTheme" parent="Theme.AppCompat.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@android:color/black</item>
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="ImageViewerDialog" parent="android:Theme.Translucent.NoTitleBar"/>
    <style name="ImageViewerDialog_Default" parent="android:Theme.Translucent.NoTitleBar">
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>
    <style name="ImageViewerDialog_NoStatusBar"
        parent="Theme.Material3.DayNight.NoActionBar">

        <!-- 关键：允许你控制状态栏 -->
        <item name="android:statusBarColor">@android:color/transparent</item>

        <!-- 黑色图标（避免白底） -->
        <item name="android:windowLightStatusBar">false</item>

        <!-- 沉浸式基础 -->
        <item name="android:windowFullscreen">false</item>

        <!-- 关键：铺满 -->
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>

        <!-- 背景 -->
        <item name="android:windowBackground">@android:color/black</item>

    </style>

    <!-- 视频播放器样式 16:9 比例 -->
    <style name="VideoPlayerStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">0dp</item>
    </style>

    <!-- 评论底部弹窗 -->
    <style name="Theme.BottomSheetDialog" parent="@style/Theme.Design.Light.BottomSheetDialog">
        <item name="android:windowIsFloating">false</item>
        <item name="bottomSheetStyle">@style/BottomSheetStyle</item>
    </style>

    <style name="BottomSheetStyle" parent="@style/Widget.Design.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
    </style>
</resources>
